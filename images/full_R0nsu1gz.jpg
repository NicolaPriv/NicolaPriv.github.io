		<script>
			const state = {
				initial: true,
				desktop: false,
				tablet: false,
				phone: false,
			}
			window.onresize = resize;
	
			const currentDevice = document.querySelector('.styleLink').getAttribute('data-device');
			state[currentDevice] = true;
	
			function resize () {
				if(!state.initial) {
					if (matchMedia('screen and (min-width : 992px)').matches && !state.desktop) {
						addTagLinkToHead('/templates/new_interior/css/main-g-theme-site-1-desktop.css');
						state.desktop = true;
					}
					if (matchMedia('screen and (min-width: 768px) and (max-width: 991px)').matches && !state.tablet) {
						addTagLinkToHead('/templates/new_interior/css/main-g-theme-site-1-tablet.css')
						state.tablet = true;
					}
					if (matchMedia('screen and (max-width : 768px)').matches && !state.phone) {
						addTagLinkToHead('/templates/new_interior/css/main-g-theme-site-1-phone.css');
						state.phone = true;
					}
				}
				state.initial = false;
			}
	
			function addTagLinkToHead(href) {
				const isCecutient = false;
				const tagLink = document.createElement('link');
				tagLink.rel = 'stylesheet';
				tagLink.href = href;
				if (isCecutient) tagLink.class = 'js-style-main';
				document.head.appendChild(tagLink);
			}
		</script>
	

	
	
	
	
	
	
	
	
	
	
	
	

	
		
		
			
		
		
	
	
